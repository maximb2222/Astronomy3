<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Astronomy.Pages.SunrisePage"
             Title="Восход и закат">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="☀️ Восход и закат"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Label Text="Для выбранной даты:"
               FontSize="18"
               FontAttributes="Bold" />

        <Label Text="Восход:"
               FontSize="16"
               FontAttributes="Bold" />
        <Label x:Name="sunriseLabel" Text="--:--" />

        <Label Text="Закат:"
               FontSize="16"
               FontAttributes="Bold" />
        <Label x:Name="sunsetLabel" Text="--:--" />

    </VerticalStackLayout>

</ContentPage>